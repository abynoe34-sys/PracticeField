# Supabase — same project as the Next.js app
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=session-videos

# MediaPipe model path — leave blank for local dev (uses ../scripts/pose_landmarker_heavy.task)
# Production (Railway): set to /app/pose_landmarker_heavy.task (baked in by Dockerfile)
MEDIAPIPE_MODEL_PATH=

# Shared secret between this service and the Inngest job.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Add the same value to:
#   - Railway environment (SERVICE_SECRET)
#   - Vercel / .env.local (ANALYSIS_SERVICE_SECRET)
SERVICE_SECRET=
